<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>智能简历解析与试题生成引擎</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  <link rel="stylesheet" href="css/style.css">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: { 50:'#eef2ff', 100:'#e0e7ff', 500:'#6366f1', 600:'#4f46e5', 700:'#4338ca' }
          }
        }
      }
    }
  </script>
</head>
<body class="bg-gray-50 min-h-screen" x-data="app()" x-init="init()" x-cloak>

  <!-- Header -->
  <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-primary-500 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
        <div>
          <h1 class="text-base font-semibold text-gray-900 leading-tight">智能简历解析引擎</h1>
          <p class="text-xs text-gray-400">AI-powered Resume Analysis &amp; Interview Generator</p>
        </div>
      </div>
      <div class="flex items-center gap-4">
        <!-- Step indicator -->
        <div class="hidden sm:flex items-center gap-2 text-sm">
          <div :class="currentStep === 0 ? 'text-primary-600 font-medium' : 'text-gray-400'"
               class="flex items-center gap-1.5">
            <span :class="currentStep === 0 ? 'bg-primary-500 text-white' : 'bg-gray-200 text-gray-500'"
                  class="w-5 h-5 rounded-full text-xs flex items-center justify-center font-semibold">1</span>
            上传文件
          </div>
          <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
          <div :class="currentStep === 1 ? 'text-primary-600 font-medium' : 'text-gray-400'"
               class="flex items-center gap-1.5">
            <span :class="currentStep === 1 ? 'bg-primary-500 text-white' : 'bg-gray-200 text-gray-500'"
                  class="w-5 h-5 rounded-full text-xs flex items-center justify-center font-semibold">2</span>
            分析结果
          </div>
        </div>
        <button x-show="currentStep === 1" @click="reset()"
          class="text-sm text-gray-500 hover:text-gray-800 border border-gray-200 rounded-lg px-3 py-1.5 hover:bg-gray-50 transition-colors">
          重新分析
        </button>
      </div>
    </div>
  </header>

  <!-- Toast notifications -->
  <div class="fixed top-16 left-1/2 -translate-x-1/2 z-50 flex flex-col gap-2 pointer-events-none">
    <div x-show="errorMsg" x-transition
         class="bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 rounded-xl shadow-lg flex items-center gap-2 pointer-events-auto">
      <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd"/>
      </svg>
      <span x-text="errorMsg"></span>
    </div>
    <div x-show="successMsg" x-transition
         class="bg-green-50 border border-green-200 text-green-700 text-sm px-4 py-3 rounded-xl shadow-lg flex items-center gap-2 pointer-events-auto">
      <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
      </svg>
      <span x-text="successMsg"></span>
    </div>
  </div>

  <main class="max-w-7xl mx-auto px-6 py-8">

    <!-- ===== STEP 0: Three-Column Layout ===== -->
    <div x-show="currentStep === 0" x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0">

      <div class="text-center mb-8">
        <h2 class="text-2xl font-bold text-gray-900">智能简历分析系统</h2>
        <p class="text-gray-500 mt-1.5 text-sm">选择或上传 JD 和简历，开始 AI 智能匹配分析</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <!-- Left Column: JD Management (Blue Theme) -->
        <div class="bg-white rounded-2xl border border-gray-200 p-5 flex flex-col">
          <div class="flex items-center gap-2 mb-4">
            <div class="w-8 h-8 rounded-lg bg-blue-500 flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2-2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <h3 class="font-semibold text-gray-900 flex-1">JD 管理</h3>
            <span class="text-xs bg-blue-50 text-blue-600 px-2 py-1 rounded-full font-medium"
              x-text="jdList.length"></span>
          </div>

          <!-- JD List -->
          <div class="flex-1 mb-4">
            <div x-show="jdList.length === 0" class="text-center py-12">
              <svg class="w-12 h-12 text-gray-300 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              <p class="text-sm text-gray-400">暂无 JD，请上传第一份</p>
            </div>

            <div x-show="jdList.length > 0" class="max-h-72 overflow-y-auto list-scroll space-y-2">
              <template x-for="jd in jdList" :key="jd.id">
                <button @click="selectJd(jd.id)" type="button"
                  class="w-full text-left p-3 rounded-xl border-2 transition-all list-item-enter"
                  :class="selectedJdId === jd.id ? 'border-blue-500 bg-blue-50' : 'border-gray-100 hover:border-blue-200 hover:bg-gray-50'">
                  <div class="flex items-start gap-2">
                    <div class="w-8 h-8 rounded-lg bg-blue-100 flex items-center justify-center shrink-0 mt-0.5">
                      <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                      </svg>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-semibold text-gray-900 truncate" x-text="jd.title"></p>
                      <p class="text-xs text-gray-400 mt-0.5" x-text="formatDate(jd.createdAt)"></p>
                    </div>
                    <div x-show="selectedJdId === jd.id" class="shrink-0">
                      <svg class="w-5 h-5 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                      </svg>
                    </div>
                  </div>
                </button>
              </template>
            </div>
          </div>

          <!-- Upload New JD -->
          <div class="border-t border-gray-100 pt-4">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-7 h-7 rounded-lg bg-blue-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2-2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <h3 class="font-semibold text-gray-800">职位描述 (JD)</h3>
              <span class="ml-auto text-xs text-red-500 font-medium">必填</span>
            </div>

            <div x-show="!jdFile"
              class="border-2 border-dashed border-gray-200 rounded-xl p-6 text-center transition-all"
              :class="isDraggingJd ? 'drag-over' : 'hover:border-primary-300 hover:bg-gray-50'"
              @dragover.prevent="isDraggingJd = true"
              @dragleave="isDraggingJd = false"
              @drop.prevent="handleJdDrop($event)">
              <svg class="w-8 h-8 text-gray-300 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
              </svg>
              <p class="text-sm text-gray-400 mb-3">将文件拖拽至此，或点击下方按鈕选择</p>
              <button type="button" @click="$refs.jdInput.click()"
                class="inline-flex items-center gap-2 px-4 py-2 bg-blue-500 hover:bg-blue-600 active:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors shadow-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/>
                </svg>
                选择 JD 文件
              </button>
              <p class="text-xs text-gray-400 mt-2">支持 PDF / DOCX</p>
              <input type="file" x-ref="jdInput" class="hidden" accept=".pdf,.docx" @change="handleJdFile($event)">
            </div>

            <div x-show="jdFile" class="flex items-center gap-3 bg-blue-50 rounded-xl p-3.5">
              <div class="w-9 h-9 bg-blue-100 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-800 truncate" x-text="jdFile?.name"></p>
                <p class="text-xs text-gray-500" x-text="formatFileSize(jdFile?.size || 0)"></p>
              </div>
              <button @click="jdFile = null; $refs.jdInput.value = ''"
                class="text-gray-400 hover:text-red-500 transition-colors p-1">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- Resume Upload -->
          <div class="bg-white rounded-2xl border border-gray-200 p-6">
            <div class="flex items-center gap-2 mb-4">
              <div class="w-7 h-7 rounded-lg bg-purple-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <h3 class="font-semibold text-gray-800">候选人简历</h3>
              <span class="text-xs text-gray-400 ml-1">可批量上传</span>
              <span class="ml-auto text-xs text-red-500 font-medium">必填</span>
            </div>

            <div class="border-2 border-dashed border-gray-200 rounded-xl p-6 text-center transition-all mb-3"
              :class="isDraggingResume ? 'drag-over' : 'hover:border-primary-300 hover:bg-gray-50'"
              @dragover.prevent="isDraggingResume = true"
              @dragleave="isDraggingResume = false"
              @drop.prevent="handleResumeDrop($event)">
              <svg class="w-8 h-8 text-gray-300 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
              </svg>
              <p class="text-sm text-gray-400 mb-3">将文件拖拽至此，或点击下方按鈕选择</p>
              <button type="button" @click="$refs.resumeInput.click()"
                class="inline-flex items-center gap-2 px-4 py-2 bg-purple-500 hover:bg-purple-600 active:bg-purple-700 text-white text-sm font-medium rounded-lg transition-colors shadow-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                选择简历文件
              </button>
              <p class="text-xs text-gray-400 mt-2">支持 PDF / DOCX，可多选</p>
              <input type="file" x-ref="resumeInput" class="hidden" accept=".pdf,.docx" multiple @change="handleResumeFiles($event)">
            </div>

            <div x-show="resumeFiles.length > 0" class="space-y-2">
              <template x-for="(file, index) in resumeFiles" :key="index">
                <div class="flex items-center gap-3 bg-purple-50 rounded-xl p-3 fade-in-up">
                  <div class="w-8 h-8 bg-purple-100 rounded-lg flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-gray-800 truncate" x-text="file.name"></p>
                    <p class="text-xs text-gray-500" x-text="formatFileSize(file.size)"></p>
                  </div>
                  <button @click="removeResume(index)" class="text-gray-400 hover:text-red-500 transition-colors p-1">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                    </svg>
                  </button>
                </div>
              </template>
            </div>
          </div>

          <!-- Submit -->
          <button @click="startAnalysis()" :disabled="!canStart"
            class="w-full py-3.5 rounded-2xl font-semibold text-white transition-all text-sm
                   disabled:opacity-40 disabled:cursor-not-allowed"
            :class="canStart ? 'bg-primary-500 hover:bg-primary-600 shadow-md hover:shadow-lg' : 'bg-gray-300'">
            <span x-show="!loading">开始 AI 分析</span>
            <span x-show="loading" class="flex items-center justify-center gap-2">
              <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
              </svg>
              <span x-text="loadingMsg || '处理中...'"></span>
            </span>
          </button>
        </div>
      </div>
    </div>
    <!-- END STEP 1 -->


    <!-- ===== STEP 2: Results ===== -->
    <div x-show="currentStep === 1" x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 translate-y-2" x-transition:enter-end="opacity-100 translate-y-0">
      <div class="flex gap-6">
        <!-- Left sidebar -->
        <div class="w-80 shrink-0">
          <div class="bg-white rounded-2xl border border-gray-200 sticky top-20">
            <div class="p-4 border-b border-gray-100">
              <h3 class="font-semibold text-gray-800 text-sm flex items-center gap-2">
                候选人列表
                <span class="ml-auto text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full" x-text="matchResults.length"></span>
              </h3>
            </div>
            <div class="max-h-[calc(100vh-12rem)] overflow-y-auto sidebar-scroll p-2">
              <template x-for="(result, index) in matchResults" :key="result.resumeId">
                <button @click="selectResume(result)"
                  class="w-full text-left p-3 rounded-xl mb-2 transition-all fade-in-up"
                  :class="selectedResume?.resumeId === result.resumeId ? 'bg-primary-50 border-2 border-primary-500' : 'bg-gray-50 border border-gray-100 hover:bg-gray-100'">
                  <div class="flex items-center gap-3">
                    <div class="relative">
                      <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary-400 to-primary-600 flex items-center justify-center text-white font-semibold text-sm"
                        x-text="(result.candidateName || '候').charAt(0)"></div>
                      <div class="absolute -bottom-0.5 -right-0.5 w-4 h-4 rounded-full flex items-center justify-center text-[10px] font-bold"
                        :class="result.score >= 80 ? 'bg-green-500 text-white' : result.score >= 60 ? 'bg-yellow-400 text-white' : 'bg-red-400 text-white'">
                        <span x-text="result.score"></span>
                      </div>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-semibold text-gray-800 truncate"
                        x-text="result.candidateName || '候选人 ' + (index + 1)"></p>
                      <div class="flex items-center gap-1.5 mt-0.5">
                        <span class="text-xs px-1.5 py-0.5 rounded border font-medium"
                          :class="recommendColor(result.recommendation)"
                          x-text="recommendLabel(result.recommendation)"></span>
                        <span class="text-xs text-gray-400" x-text="'匹配度 ' + result.score + '%'"></span>
                      </div>
                    </div>
                  </div>
                </button>
              </template>
            </div>
          </div>
        </div>

        <!-- Right: Detail Panel -->
        <div class="flex-1 min-w-0">
          <!-- Empty state -->
          <div x-show="!selectedResume" class="flex items-center justify-center h-64">
            <div class="text-center">
              <svg class="w-16 h-16 text-gray-200 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
              <p class="text-gray-400 text-sm">请从左侧选择候选人查看详情</p>
            </div>
          </div>

          <!-- Detail content -->
          <div x-show="selectedResume">
            <!-- Header Card -->
            <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-6">
              <div class="flex items-start justify-between">
                <div class="flex-1">
                  <h2 class="text-2xl font-bold text-gray-900 mb-1"
                    x-text="selectedResume?.candidateName || '候选人详情'"></h2>
                  <div class="flex items-center gap-3 mt-3">
                    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border text-sm font-medium"
                      :class="recommendColor(selectedResume?.recommendation)">
                      <span x-text="recommendLabel(selectedResume?.recommendation)"></span>
                    </span>
                    <div class="h-4 w-px bg-gray-200"></div>
                    <span class="text-sm text-gray-500">匹配分析报告</span>
                  </div>
                </div>
                <div class="text-center">
                  <div class="relative inline-flex items-center justify-center">
                    <svg class="w-24 h-24 transform -rotate-90">
                      <circle cx="48" cy="48" r="38" stroke="#e5e7eb" stroke-width="8" fill="none"/>
                      <circle cx="48" cy="48" r="38" stroke="currentColor" stroke-width="8" fill="none"
                        :class="scoreBarColor(selectedResume?.score || 0)"
                        stroke-dasharray="240"
                        :stroke-dashoffset="240 - (240 * (selectedResume?.score || 0) / 100)"
                        class="score-ring" stroke-linecap="round"/>
                    </svg>
                    <div class="absolute inset-0 flex flex-col items-center justify-center">
                      <span class="text-2xl font-bold" :class="scoreColor(selectedResume?.score || 0)"
                        x-text="selectedResume?.score"></span>
                      <span class="text-xs text-gray-400">分</span>
                    </div>
                  </div>
                </div>
              </div>

              <div class="mt-6 p-4 bg-gray-50 rounded-xl">
                <p class="text-sm text-gray-700 leading-relaxed" x-text="selectedResume?.reason"></p>
              </div>

              <!-- Dimension bars -->
              <div class="mt-6 grid grid-cols-2 gap-4"
                x-show="selectedResume?.dimensions && Object.keys(selectedResume.dimensions).length > 0">
                <template x-for="(value, key) in selectedResume?.dimensions" :key="key">
                  <div>
                    <div class="flex items-center justify-between mb-1.5">
                      <span class="text-xs font-medium text-gray-600" x-text="key"></span>
                      <span class="text-xs font-semibold" :class="scoreColor(value)" x-text="value"></span>
                    </div>
                    <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
                      <div class="h-full rounded-full bar-width-transition"
                        :class="scoreBarColor(value)" :style="'width: ' + value + '%'"></div>
                    </div>
                  </div>
                </template>
              </div>

              <!-- Strengths & Gaps -->
              <div class="mt-6 grid grid-cols-2 gap-4">
                <div x-show="selectedResume?.strengths?.length > 0">
                  <h4 class="text-xs font-semibold text-green-600 mb-2 flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>优势亮点
                  </h4>
                  <ul class="space-y-1.5">
                    <template x-for="item in selectedResume?.strengths" :key="item">
                      <li class="text-xs text-gray-600 flex items-start gap-1.5">
                        <span class="text-green-400 mt-0.5">●</span>
                        <span x-text="item"></span>
                      </li>
                    </template>
                  </ul>
                </div>
                <div x-show="selectedResume?.gaps?.length > 0">
                  <h4 class="text-xs font-semibold text-orange-600 mb-2 flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                    </svg>待评估点
                  </h4>
                  <ul class="space-y-1.5">
                    <template x-for="item in selectedResume?.gaps" :key="item">
                      <li class="text-xs text-gray-600 flex items-start gap-1.5">
                        <span class="text-orange-400 mt-0.5">●</span>
                        <span x-text="item"></span>
                      </li>
                    </template>
                  </ul>
                </div>
              </div>
            </div>

            <!-- Interview Tabs -->
            <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
              <div class="flex border-b border-gray-100">
                <button @click="activeTab = 'questions'"
                  class="flex-1 px-6 py-3.5 text-sm font-medium transition-colors relative"
                  :class="activeTab === 'questions' ? 'text-primary-600 bg-primary-50' : 'text-gray-500 hover:text-gray-700'">
                  <span class="flex items-center justify-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    面试题目
                    <span class="text-xs bg-primary-100 text-primary-600 px-2 py-0.5 rounded-full"
                      x-text="questions.length"></span>
                  </span>
                  <div x-show="activeTab === 'questions'"
                    class="absolute bottom-0 left-0 right-0 h-0.5 bg-primary-500"></div>
                </button>
                <button @click="activeTab = 'followup'"
                  class="flex-1 px-6 py-3.5 text-sm font-medium transition-colors relative"
                  :class="activeTab === 'followup' ? 'text-primary-600 bg-primary-50' : 'text-gray-500 hover:text-gray-700'">
                  <span class="flex items-center justify-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                    </svg>
                    针对性追问
                    <span class="text-xs bg-primary-100 text-primary-600 px-2 py-0.5 rounded-full"
                      x-text="followups.length"></span>
                  </span>
                  <div x-show="activeTab === 'followup'"
                    class="absolute bottom-0 left-0 right-0 h-0.5 bg-primary-500"></div>
                </button>
              </div>

              <!-- Loading -->
              <div x-show="loadingQuestions" class="p-12 text-center">
                <div class="spinner mx-auto mb-3"></div>
                <p class="text-sm text-gray-500">AI 正在生成面试题...</p>
              </div>

              <!-- Questions Tab -->
              <div x-show="activeTab === 'questions' && !loadingQuestions" class="p-6">
                <div x-show="questions.length === 0" class="text-center py-12">
                  <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                  </svg>
                  <p class="text-sm text-gray-400">暂无面试题</p>
                </div>
                <div class="space-y-4">
                  <template x-for="(q, index) in questions" :key="q.id || index">
                    <div class="bg-gray-50 rounded-xl p-5 border border-gray-100 fade-in-up hover:shadow-sm transition-shadow">
                      <div class="flex items-start justify-between mb-3">
                        <div class="flex items-center gap-2">
                          <span class="w-6 h-6 rounded-full bg-primary-500 text-white text-xs font-bold flex items-center justify-center"
                            x-text="index + 1"></span>
                          <span class="text-xs px-2 py-1 rounded-lg font-medium"
                            :class="categoryColor(q.category)" x-text="categoryLabel(q.category)"></span>
                        </div>
                        <span class="text-xs text-gray-400" x-text="difficultyLabel(q.difficulty)"></span>
                      </div>
                      <p class="text-sm font-medium text-gray-900 mb-3" x-text="q.question"></p>
                      <div x-show="q.keyPoints && q.keyPoints.length > 0" class="mb-3">
                        <p class="text-xs font-semibold text-gray-500 mb-1.5">考察要点:</p>
                        <ul class="space-y-1">
                          <template x-for="point in q.keyPoints" :key="point">
                            <li class="text-xs text-gray-600 flex items-start gap-1.5">
                              <span class="text-primary-400 mt-0.5">▸</span>
                              <span x-text="point"></span>
                            </li>
                          </template>
                        </ul>
                      </div>
                      <div x-show="q.scoringCriteria" class="pt-3 border-t border-gray-200">
                        <p class="text-xs font-semibold text-gray-500 mb-1">评分标准:</p>
                        <p class="text-xs text-gray-600" x-text="q.scoringCriteria"></p>
                      </div>
                    </div>
                  </template>
                </div>
              </div>

              <!-- Follow-up Tab -->
              <div x-show="activeTab === 'followup' && !loadingQuestions" class="p-6">
                <div x-show="followups.length === 0" class="text-center py-12">
                  <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                  </svg>
                  <p class="text-sm text-gray-400">暂无追问题</p>
                </div>
                <div class="space-y-4">
                  <template x-for="(q, index) in followups" :key="q.id || index">
                    <div class="bg-orange-50 rounded-xl p-5 border border-orange-100 fade-in-up hover:shadow-sm transition-shadow">
                      <div class="flex items-start gap-3 mb-3">
                        <span class="w-6 h-6 rounded-full bg-orange-500 text-white text-xs font-bold flex items-center justify-center shrink-0"
                          x-text="index + 1"></span>
                        <p class="text-sm font-medium text-gray-900 flex-1" x-text="q.question"></p>
                      </div>
                      <div x-show="q.context" class="mb-2 pl-9">
                        <p class="text-xs font-semibold text-orange-600 mb-1">简历上下文:</p>
                        <p class="text-xs text-gray-600 italic" x-text="q.context"></p>
                      </div>
                      <div x-show="q.reason" class="pl-9">
                        <p class="text-xs font-semibold text-orange-600 mb-1">追问原因:</p>
                        <p class="text-xs text-gray-600" x-text="q.reason"></p>
                      </div>
                    </div>
                  </template>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
    <!-- END STEP 2 -->

  </main>

  <script src="js/app.js"></script>
</body>
</html>